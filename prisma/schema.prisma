generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  OPERATOR
  ADMIN
}

enum StudyStatus {
  UPLOADED
  PROCESSING
  READY
}

model Institution {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  sites Site[]
  users User[]
}

model Site {
  id            String   @id @default(cuid())
  name          String
  institutionId String
  createdAt     DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id])

  studies Study[]
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          UserRole
  institutionId String
  createdAt     DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id])

  studies Study[]
  comments StudyComment[]
}

model Patient {
  id          String   @id @default(cuid())
  patientId   String
  patientName String
  createdAt   DateTime @default(now())

  studies Study[]
}

model Study {
  id               String      @id @default(cuid())
  studyDescription String
  modality         String
  status           StudyStatus @default(UPLOADED)

  patientId String
  siteId    String
  userId    String

  imagingLink String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  site Site @relation(fields: [siteId], references: [id])

  user User @relation(fields: [userId], references: [id])

  files StudyFile[]

  report Report?

  comments StudyComment[]
}

model StudyFile {
  id String @id @default(cuid())

  studyId String

  fileName String
  fileUrl  String
  fileType String

  createdAt DateTime @default(now())

  study Study @relation(fields: [studyId], references: [id])
}

model Report {
  id String @id @default(cuid())

  studyId String @unique

  reportUrl String

  uploadedAt DateTime @default(now())

  study Study @relation(fields: [studyId], references: [id])
}

model StudyComment {
  id String @id @default(cuid())

  studyId String
  userId  String

  message String

  createdAt DateTime @default(now())

  study Study @relation(fields: [studyId], references: [id])

  user User @relation(fields: [userId], references: [id])
}